wfasta <- function(fasta_data, f) {
  fileconn <- file(f)
  writeLines(t(fasta_data), fileconn)
  close(fileconn)
}

samread <- function(g,l) {
  fa_raw <- fread(cmd = paste("samtools faidx", g, l), header = F, fill = T, sep = "\n")
  fa_raw[, h := grepl(">", V1)]
  fa_oneline <- fa_raw[, .(paste0(V1, collapse = "")), by = rleid(h)]
  return(data.table(name = fa_oneline[rep(c(TRUE, FALSE), length = .N)]$V1, 
                    seq = fa_oneline[rep(c(FALSE, TRUE), length = .N)]$V1))
}

## Original code from: https://github.com/etam4260/kneedle/blob/main/R/kneedle.R
kneedle <- function(x, y, decreasing, concave, sensitivity = 1) {
  data <- matrix(unlist(list(x, y)), ncol = 2)
  data <- data[order(data[,1], decreasing = FALSE), ]
  if(missing(decreasing)) {
    if( (data[(nrow(data)), 2] - data[1, 2]) >= 0 ) {
      decreasing = FALSE
    } else {
      decreasing = TRUE
    }
  }
  if(missing(concave)) {
    secondderiv <- diff(diff(data[, 2]) / diff(data[, 1]))
    if(mean(secondderiv) > 0) {
      concave = TRUE
    } else {
      concave = FALSE
    }
  }
  maxy <- max(y)
  miny <- min(y)
  maxx <- max(x)
  minx <- min(x)
  data[ ,1] <- (data[, 1]- min(data[, 1]))/(max(data[ ,1])- min(data[, 1]))
  data[ ,2] <- (data[, 2]- min(data[, 2]))/(max(data[ ,2])- min(data[, 2]))
  if(concave && !decreasing) {
    differ <- abs(c(data[ ,2] - data[ ,1]))
  } else if(concave && decreasing) {
    differ <- abs(c(data[ ,2] - (1 - data[ ,1])))
  } else if(!concave && !decreasing) {
    differ <- abs(c(data[ ,2] - data[ ,1]))
  } else if(!concave && decreasing) {
    differ <- abs(c(data[ ,2] - (1 - data[ ,1])))
  }
  peak.indices <- findPeaks(differ) - 1
  data <- cbind(data, differ)
  diffx = diff(data[, 1])
  T.lm.x.s <- sensitivity * mean(diffx)
  knee = NULL
  for(i in 1:length(peak.indices)) {
    T <- data[peak.indices[i] ,3] - (T.lm.x.s)
    y.value <- data[peak.indices[i] ,3]
    for(j in (peak.indices[i]):if(i+1 < length(peak.indices)) peak.indices[i+1] else length(differ)) {
      if(differ[j] < T) {
        knee = peak.indices[i];
        break;
      }
    }
    if(!is.null(knee)) {
      break;
    }
  }
  x <- ((maxx - minx) * (data[knee, 1])) + minx
  y <- ((maxy - miny) * (data[knee, 2])) + miny
  return(c(as.numeric(x),as.numeric(y)))
}


split_intervals_by_bins <- function(dt, bin_size) {
  dt[, row_id := .I]
  result <- dt[, {
    first_bin <- floor(V2 / bin_size)
    last_bin  <- floor(V3 / bin_size)
    if (first_bin == last_bin) {
      .(V2 = as.numeric(V2), V3 = as.numeric(V3), V4=V4)
    } else {
      bins   <- first_bin:last_bin
      starts <- pmax(as.numeric(V2), bins * bin_size)
      ends   <- pmin(as.numeric(V3), (bins + 1) * bin_size - 1)
      .(V2 = starts, V3 = ends, V4=V4)
    }
  }, by = .(V1, row_id)]
  result[, row_id := NULL]
  dt[, row_id := NULL]
  return(result)
}

interval_quantile <- function(dt, probs = c(0.25, 0.5, 0.75)) {
 # dominant_v4 <- dt[, .SD[which.max(V3 - V2), .(V4)], by = V1]
  dominant_v4 <- bed[cnt > 5][, sl := sum(len), c("V1","V4")][order(-sl)][, .SD[1], V1][,c(1,4)]
  dt_filtered <- dt[dominant_v4, on = .(V1, V4), nomatch = 0]
  result <- dt_filtered[order(V2), {
    lengths  <- V3 - V2 + 1
    total    <- sum(lengths)
    cum_len  <- cumsum(lengths)
    dominant <- unique(V4)
    quants <- sapply(probs, function(p) {
      target   <- p * (total - 1) + 1
      i        <- which.min(cum_len < target)
      prev_cum <- if (i == 1) 0 else cum_len[i - 1]
      offset   <- target - prev_cum - 1
      V2[i] + floor(offset)
    })
    c(list(V4 = dominant), setNames(as.list(quants), c("start","end")))
  }, by = V1]
  return(result)
}


